<Window x:Class="SoochakBharat.Demo.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SoochakBharat.Demo.Desktop.ViewModels"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:models="clr-namespace:SoochakBharat.Demo.Desktop.Models"
        Title="SoochakBharat RFID Studio"
        Height="800"
        Width="1200"
        Background="{StaticResource LightBackground}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Readers View -->
        <DataTemplate DataType="{x:Type vm:ReaderViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                <StackPanel>
                    <TextBlock Text="Reader Connection" Style="{StaticResource HeadingStyle}" Margin="0,0,0,20"/>
                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                <TextBlock Text="Reader Address" Style="{StaticResource SubtextStyle}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Height="40"/>
                                
                                <TextBlock Text="Antenna Ports" Style="{StaticResource SubtextStyle}" Margin="0,12,0,4"/>
                                <ComboBox SelectedValue="{Binding AntennaPorts}" Height="40">
                                    <ComboBoxItem Content="1"/>
                                    <ComboBoxItem Content="2"/>
                                    <ComboBoxItem Content="4"/>
                                    <ComboBoxItem Content="8"/>
                                    <ComboBoxItem Content="16"/>
                                </ComboBox>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                    <Button Content="Connect" Command="{Binding ConnectCommand}" Width="120" Height="40"/>
                                    <Button Content="Disconnect" Command="{Binding DisconnectCommand}" Width="120" Height="40" Style="{StaticResource SecondaryButton}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Status}" Margin="0,12,0,0" Style="{StaticResource SubtextStyle}"/>
                            </StackPanel>
                            
                            <Border Grid.Column="1" Background="{StaticResource LightBackground}" Padding="20" CornerRadius="12" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Reader Identity" FontFamily="Segoe UI Semibold" FontSize="16" Margin="0,0,0,12"/>
                                    <Separator Margin="0,0,0,12" Background="{StaticResource BorderSubtle}"/>
                                    <TextBlock Text="{Binding Identity.Address, StringFormat=Address: {0}}" Style="{StaticResource SubtextStyle}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding Identity.Model, StringFormat=Model: {0}}" Style="{StaticResource SubtextStyle}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding Identity.Firmware, StringFormat=Firmware: {0}}" Style="{StaticResource SubtextStyle}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding Identity.Region, StringFormat=Region: {0}}" Style="{StaticResource SubtextStyle}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding Identity.Status, StringFormat=Status: {0}}" FontFamily="Segoe UI Semibold" Foreground="{StaticResource PrimaryBlue}" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- Inventory View -->
        <DataTemplate DataType="{x:Type vm:InventoryViewModel}">
            <DockPanel Margin="24">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,16">
                    <Button Content="Start Inventory" Command="{Binding StartCommand}" Height="40"/>
                    <Button Content="Stop Inventory" Command="{Binding StopCommand}" Height="40" Style="{StaticResource SecondaryButton}"/>
                    <Button Content="Clear" Command="{Binding ClearCommand}" Height="40" Style="{StaticResource SecondaryButton}"/>
                    <CheckBox Content="Deduplicate" IsChecked="{Binding Deduplicate}" Foreground="{StaticResource TextPrimary}" Margin="16,0,0,0" VerticalAlignment="Center" FontSize="14"/>
                </StackPanel>

                <Border Style="{StaticResource CardStyle}" Margin="0">
                    <DataGrid ItemsSource="{Binding Tags}"
                              AutoGenerateColumns="False"
                              Background="{StaticResource CardBackground}"
                              Foreground="{StaticResource TextPrimary}"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              BorderThickness="0"
                              RowHeaderWidth="0"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Extended">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="EPC" Binding="{Binding Epc}" Width="*" CanUserResize="True">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{StaticResource LightBackground}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                        <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
                                        <Setter Property="Padding" Value="12,10"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="12,10"/>
                                        <Setter Property="FontFamily" Value="Segoe UI"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Antenna" Binding="{Binding Antenna}" Width="90" CanUserResize="True">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{StaticResource LightBackground}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                        <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
                                        <Setter Property="Padding" Value="12,10"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="12,10"/>
                                        <Setter Property="FontFamily" Value="Segoe UI"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="RSSI" Binding="{Binding Rssi}" Width="90" CanUserResize="True">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{StaticResource LightBackground}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                        <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
                                        <Setter Property="Padding" Value="12,10"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="12,10"/>
                                        <Setter Property="FontFamily" Value="Segoe UI"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Read Count" Binding="{Binding ReadCount}" Width="110" CanUserResize="True">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{StaticResource LightBackground}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                        <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
                                        <Setter Property="Padding" Value="12,10"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="12,10"/>
                                        <Setter Property="FontFamily" Value="Segoe UI"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Frequency (kHz)" Binding="{Binding FrequencyKHz}" Width="130" CanUserResize="True">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{StaticResource LightBackground}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                        <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
                                        <Setter Property="Padding" Value="12,10"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="12,10"/>
                                        <Setter Property="FontFamily" Value="Segoe UI"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Timestamp" Binding="{Binding TimestampDisplay}" Width="180" CanUserResize="True">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{StaticResource LightBackground}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                        <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
                                        <Setter Property="Padding" Value="12,10"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="12,10"/>
                                        <Setter Property="FontFamily" Value="Segoe UI"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </DockPanel>
        </DataTemplate>

        <!-- Antennas View -->
        <DataTemplate DataType="{x:Type vm:AntennaViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                <StackPanel>
                    <TextBlock Text="Antennas" Style="{StaticResource HeadingStyle}" Margin="0,0,0,20"/>
                    <ItemsControl ItemsSource="{Binding Ports}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardStyle}" Margin="8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Index, StringFormat=Port {0}}" FontFamily="Segoe UI Semibold" FontSize="16" Margin="0,0,0,12"/>
                                        <ToggleButton Content="Active"
                                                      IsChecked="{Binding IsEnabled}"
                                                      Command="{Binding DataContext.ToggleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      CommandParameter="{Binding}"
                                                      Height="36"
                                                      Background="{StaticResource PrimaryBlue}"
                                                      Foreground="White"
                                                      BorderThickness="0"
                                                      FontFamily="Segoe UI Semibold"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- Performance View -->
        <DataTemplate DataType="{x:Type vm:PerformanceViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                <UniformGrid Columns="2" Rows="2">
                    <Border Style="{StaticResource CardStyle}" Margin="8">
                        <StackPanel>
                            <TextBlock Text="Tags / sec" Style="{StaticResource SubtextStyle}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding TagsPerSecond}" FontFamily="Segoe UI Semibold" FontSize="32" Foreground="{StaticResource PrimaryBlue}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}" Margin="8">
                        <StackPanel>
                            <TextBlock Text="Average RSSI" Style="{StaticResource SubtextStyle}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding AvgRssi}" FontFamily="Segoe UI Semibold" FontSize="32" Foreground="{StaticResource PrimaryBlue}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}" Margin="8">
                        <StackPanel>
                            <TextBlock Text="Active Antennas" Style="{StaticResource SubtextStyle}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding ActiveAntennas}" FontFamily="Segoe UI Semibold" FontSize="32" Foreground="{StaticResource PrimaryBlue}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}" Margin="8">
                        <StackPanel>
                            <TextBlock Text="Inventory Uptime" Style="{StaticResource SubtextStyle}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding Uptime}" FontFamily="Segoe UI Semibold" FontSize="32" Foreground="{StaticResource PrimaryBlue}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </ScrollViewer>
        </DataTemplate>

        <!-- Events View -->
        <DataTemplate DataType="{x:Type vm:EventsViewModel}">
            <DockPanel Margin="24">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,16">
                    <ComboBox ItemsSource="{Binding Source={StaticResource LogLevels}}"
                              SelectedItem="{Binding SelectedLevel}"
                              Width="180"
                              Height="40"
                              Margin="0,0,12,0"/>
                    <Button Content="Export Logs" Command="{Binding ExportCommand}" Height="40"/>
                </StackPanel>
                <Border Style="{StaticResource CardStyle}" Margin="0">
                    <ListView ItemsSource="{Binding FilteredEvents}" 
                              Background="{StaticResource CardBackground}"
                              Foreground="{StaticResource TextPrimary}"
                              BorderThickness="0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="12,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss.fff}}" Width="100" Style="{StaticResource SubtextStyle}"/>
                                        <TextBlock Text="{Binding Level}" Width="80" Margin="12,0,0,0" FontFamily="Segoe UI Semibold"/>
                                        <TextBlock Text="{Binding Message}" Margin="12,0,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </DockPanel>
        </DataTemplate>

        <!-- Settings View -->
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                <StackPanel>
                    <TextBlock Text="Settings" Style="{StaticResource HeadingStyle}" Margin="0,0,0,20"/>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Region" Style="{StaticResource SubtextStyle}" Margin="0,0,0,4"/>
                            <ComboBox SelectedValue="{Binding Region}" Height="40" Margin="0,0,0,20">
                                <ComboBoxItem Content="NA"/>
                                <ComboBoxItem Content="EU"/>
                            </ComboBox>
                            <TextBlock Text="Protocol" Style="{StaticResource SubtextStyle}" Margin="0,0,0,4"/>
                            <ComboBox SelectedValue="{Binding Protocol}" Height="40" Margin="0,0,0,20">
                                <ComboBoxItem Content="GEN2"/>
                            </ComboBox>
                            <StackPanel Visibility="{Binding SupportsSession, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,20">
                                <TextBlock Text="Session" Style="{StaticResource SubtextStyle}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding SessionValue}" Height="40"/>
                            </StackPanel>
                            <Button Content="Save Settings" Command="{Binding SaveCommand}" Width="140" Height="40"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Style="{StaticResource CardStyle}" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="Reader Capabilities" FontFamily="Segoe UI Semibold" FontSize="16" Margin="0,0,0,12"/>
                            <Separator Margin="0,0,0,12" Background="{StaticResource BorderSubtle}"/>
                            <TextBlock Text="{Binding CapabilitiesText}" Style="{StaticResource SubtextStyle}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" 
                Background="{StaticResource CardBackground}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- App Title -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="0">
                    <TextBlock Text="📡" FontSize="24" Margin="0,0,12,0"/>
                    <TextBlock Text="SoochakBharat RFID Studio" 
                               FontFamily="Segoe UI Semibold" 
                               FontSize="18" 
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- Window Controls (handled by OS) -->
            </Grid>
        </Border>

        <!-- Left Navigation -->
        <Border Grid.Row="1" Grid.Column="0" 
                Background="{StaticResource NavyNavBg}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="20,24">
                <ListBox ItemsSource="{Binding Navigation}"
                         SelectedItem="{Binding SelectedNav}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="White">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="12,10"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0B4ED6"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Icon}" 
                                           FontFamily="Segoe MDL2 Assets" 
                                           FontSize="18"
                                           Margin="0,0,12,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Title}" 
                                           FontFamily="Segoe UI Semibold"
                                           FontSize="14"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- Content Area -->
        <Border Grid.Row="1" Grid.Column="1" 
                Background="{StaticResource LightBackground}">
            <ContentControl Content="{Binding CurrentViewModel}"/>
        </Border>
    </Grid>
</Window>
