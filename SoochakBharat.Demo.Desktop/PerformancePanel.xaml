<UserControl x:Class="SoochakBharat.Demo.Desktop.PerformancePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <UniformGrid Columns="2" Rows="2">
            <Border Style="{StaticResource CardStyle}" Margin="8">
                <StackPanel>
                    <TextBlock Text="Tags / sec" Style="{StaticResource SubtextStyle}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding TagsPerSecond}"
                               FontFamily="Segoe UI Semibold"
                               FontSize="32"
                               Foreground="{StaticResource PrimaryBlue}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="8">
                <StackPanel>
                    <TextBlock Text="Average RSSI" Style="{StaticResource SubtextStyle}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding AvgRssi}"
                               FontFamily="Segoe UI Semibold"
                               FontSize="32"
                               Foreground="{StaticResource PrimaryBlue}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="8">
                <StackPanel>
                    <TextBlock Text="Active Antennas" Style="{StaticResource SubtextStyle}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding ActiveAntennas}"
                               FontFamily="Segoe UI Semibold"
                               FontSize="32"
                               Foreground="{StaticResource PrimaryBlue}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="8">
                <StackPanel>
                    <TextBlock Text="Inventory Uptime" Style="{StaticResource SubtextStyle}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding Uptime}"
                               FontFamily="Segoe UI Semibold"
                               FontSize="32"
                               Foreground="{StaticResource PrimaryBlue}"/>
                </StackPanel>
            </Border>
        </UniformGrid>
    </ScrollViewer>
</UserControl>


