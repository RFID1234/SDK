<UserControl x:Class="SoochakBharat.Demo.Desktop.InventoryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="24">
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,16">
            <Button Content="Start Inventory" Command="{Binding StartCommand}" Height="40"/>
            <Button Content="Stop Inventory" Command="{Binding StopCommand}" Height="40" Style="{StaticResource SecondaryButton}"/>
            <Button Content="Clear" Command="{Binding ClearCommand}" Height="40" Style="{StaticResource SecondaryButton}"/>
            <CheckBox Content="Deduplicate"
                      IsChecked="{Binding Deduplicate}"
                      Foreground="{StaticResource TextPrimary}"
                      Margin="16,0,0,0"
                      VerticalAlignment="Center"
                      FontSize="14"/>
        </StackPanel>

        <Border Style="{StaticResource CardStyle}" Margin="0">
            <DataGrid ItemsSource="{Binding Tags}"
                      AutoGenerateColumns="False"
                      Background="{StaticResource PanelBackground}"
                      Foreground="{StaticResource TextPrimary}"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      BorderThickness="0"
                      RowHeaderWidth="0"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Extended">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="EPC" Binding="{Binding Epc}" Width="*" />
                    <DataGridTextColumn Header="Antenna" Binding="{Binding Antenna}" Width="90" />
                    <DataGridTextColumn Header="RSSI" Binding="{Binding Rssi}" Width="90" />
                    <DataGridTextColumn Header="Read Count" Binding="{Binding ReadCount}" Width="110" />
                    <DataGridTextColumn Header="Frequency (kHz)" Binding="{Binding FrequencyKHz}" Width="130" />
                    <DataGridTextColumn Header="Timestamp" Binding="{Binding TimestampDisplay}" Width="180" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</UserControl>


