<UserControl x:Class="SoochakBharat.Demo.Desktop.NavPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SoochakBharat.Demo.Desktop.ViewModels"
             Background="#07243B">
    <StackPanel Margin="16,24">
        <ListBox ItemsSource="{Binding Navigation}"
                 SelectedItem="{Binding SelectedNav}"
                 Background="Transparent"
                 BorderThickness="0"
                 Foreground="White">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="12,10"/>
                    <Setter Property="Margin" Value="0,2"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#0B4ED6"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Icon}"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Margin="0,0,12,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Title}"
                                   FontFamily="Segoe UI Semibold"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </StackPanel>
</UserControl>


