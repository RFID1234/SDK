<UserControl x:Class="SoochakBharat.Demo.Desktop.ReaderCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel>
            <TextBlock Text="Reader Connection"
                       FontFamily="Segoe UI Semibold"
                       FontSize="20"
                       Foreground="{StaticResource TextPrimary}"
                       Margin="0,0,0,20"/>
            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="Reader Address" Style="{StaticResource SubtextStyle}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Height="40"/>

                        <TextBlock Text="Antenna Ports" Style="{StaticResource SubtextStyle}" Margin="0,12,0,4"/>
                        <ComboBox SelectedValue="{Binding AntennaPorts}" Height="40">
                            <ComboBoxItem Content="1"/>
                            <ComboBoxItem Content="2"/>
                            <ComboBoxItem Content="4"/>
                            <ComboBoxItem Content="8"/>
                            <ComboBoxItem Content="16"/>
                        </ComboBox>

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Content="Connect" Command="{Binding ConnectCommand}" Width="120" Height="40"/>
                            <Button Content="Disconnect" Command="{Binding DisconnectCommand}" Width="120" Height="40" Style="{StaticResource SecondaryButton}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Status}" Margin="0,12,0,0" Style="{StaticResource SubtextStyle}"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="{StaticResource PageBackground}"
                            Padding="20"
                            CornerRadius="12"
                            BorderBrush="{StaticResource BorderSubtle}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Reader Identity"
                                       FontFamily="Segoe UI Semibold"
                                       FontSize="16"
                                       Margin="0,0,0,12"/>
                            <Separator Margin="0,0,0,12" Background="{StaticResource BorderSubtle}"/>
                            <TextBlock Text="{Binding Identity.Address, StringFormat=Address: {0}}" Style="{StaticResource SubtextStyle}" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding Identity.Model, StringFormat=Model: {0}}" Style="{StaticResource SubtextStyle}" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding Identity.Firmware, StringFormat=Firmware: {0}}" Style="{StaticResource SubtextStyle}" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding Identity.Region, StringFormat=Region: {0}}" Style="{StaticResource SubtextStyle}" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding Identity.Status, StringFormat=Status: {0}}"
                                       FontFamily="Segoe UI Semibold"
                                       Foreground="{StaticResource PrimaryBlue}"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>


